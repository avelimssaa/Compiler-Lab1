digraph ATN {
rankdir=LR;
s3[fontsize=11, label="3", shape=doublecircle, fixedsize=true, width=.6];
s2[fontsize=11,label="2", shape=circle, fixedsize=true, width=.55, peripheries=1];
s35[fontsize=11,label="35", shape=circle, fixedsize=true, width=.55, peripheries=1];
s36[fontsize=11,label="36", shape=circle, fixedsize=true, width=.55, peripheries=1];
s37[fontsize=11,label="37", shape=circle, fixedsize=true, width=.55, peripheries=1];
s2 -> s35 [fontname="Times-Italic", label="&epsilon;"];
s35 -> s36 [fontsize=11, fontname="Courier", arrowsize=.7, label = "'('", arrowhead = normal];
s36 -> s37 [fontsize=11, fontname="Courier", arrowsize=.7, label = "<openBracketCycle>", arrowhead = normal];
s37 -> s3 [fontname="Times-Italic", label="&epsilon;"];
}